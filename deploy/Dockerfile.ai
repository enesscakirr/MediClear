# ============================================================
# ai-service/Dockerfile
# MediClear — Python AI Service (FastAPI + LangGraph + Ollama)
# ============================================================

FROM python:3.11-slim AS base

# System dependencies (for pillow and others) and Node.js (for MCP)
RUN apt-get update && apt-get install -y --no-install-recommends \
  gcc \
  libffi-dev \
  curl \
  gnupg \
  && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ─── Install dependencies (cache layer) ──────────────────────
COPY requirements.txt ./
# torch'un CPU versiyonunu kurarak (CUDA gereksiz) imaj boyutunu ve build süresini düşürüyoruz
RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu \
  && pip install --no-cache-dir -r requirements.txt

# ─── Copy application code ──────────────────────────────────
COPY . .

# Security: non-root user
RUN useradd -m -u 1001 mediclear && chown -R mediclear:mediclear /app
USER mediclear

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=15s --start-period=20s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

# Start in production mode (no reload)
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
