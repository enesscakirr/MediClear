# ==========================================
# SERVER YAPILANDIRMASI
# ==========================================
# Sunucunun çalışacağı port adresi (Örn: 5000)
PORT=5000

# Çalışma ortamı (development veya production)
NODE_ENV=development

# ==========================================
# VERİTABANI (MONGODB) YAPILANDIRMASI
# ==========================================
# Yerel MongoDB (Compass) veya Bulut (Atlas) bağlantı adresi
# Örnek Atlas: mongodb+srv://<username>:<password>@cluster0.../MediClear
MONGODB_URI=mongodb://127.0.0.1:27017/MediClear

# ==========================================
# GÜVENLİK VE KİMLİK DOĞRULAMA (JWT)
# ==========================================
# Token şifrelemesinde kullanılacak çok gizli anahtar.
# Üretime (Production) geçerken mutla karmaşık ve gizli bir değer atayın!
JWT_SECRET=ornek_gizli_anahtar_buraya_yazilacak

# Token'ın geçerlilik süresi (Örn: '1d' = 1 gün, '1h' = 1 saat)
JWT_EXPIRES_IN=1d

# ==========================================
# YAPAY ZEKA (OLLAMA API) YAPILANDIRMASI
# ==========================================
# Yerelde çalışan Ollama sunucusunun API adresi (Varsayılan port 11434)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Görsel analiz modeli
# OLLAMA_VISION_MODEL=llava
# Chat/RAG destek modeli
# OLLAMA_CHAT_MODEL=mistral
