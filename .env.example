# ============================================================
# MediClear — .env.example
# Gerçek değerleri .env dosyasına kopyalayarak doldurun.
# .env dosyasını ASLA Git'e commit etmeyin!
# ============================================================

# ─── NODE.JS SUNUCU ──────────────────────────────────────────
# Express.js'in dinleyeceği port numarası
PORT=5000

# Çalışma ortamı: 'development' veya 'production'
NODE_ENV=development

# ─── VERİTABANI (MONGODB) ────────────────────────────────────
# Yerel kurulum (Docker dışı) için:
MONGODB_URI=mongodb://127.0.0.1:27017/MediClear

# Docker Compose içinde servisler birbirine isimle ulaşır.
# docker-compose.yml veya Docker ortamında şunu kullanın:
# MONGODB_URI=mongodb://db:27017/MediClear

# MongoDB Atlas (bulut) için:
# MONGODB_URI=mongodb+srv://<kullanıcı_adı>:<şifre>@cluster0.xxxxx.mongodb.net/mediclear?retryWrites=true&w=majority

# ─── GÜVENLİK (JWT) ──────────────────────────────────────────
# JWT token imzalama anahtarı — üretimde güçlü ve rastgele bir değer kullanın!
# Örnek üretmek için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=buraya_guclu_bir_gizli_anahtar_girin

# JWT token geçerlilik süresi: '1d' = 1 gün, '7d' = 7 gün, '1h' = 1 saat
JWT_EXPIRES_IN=1d

# ─── SERVİSLER ARASI İLETİŞİM ────────────────────────────────
# Node.js'in Python AI servisine ulaşacağı adres:
# Yerel kurulum: http://localhost:8000
# Docker Compose: http://ai-service:8000
AI_SERVICE_URL=http://localhost:8000

# ─── PYTHON AI SERVİSİ (LangGraph + Ollama) ─────────────────
# Ollama sunucusunun çalıştığı adres:
# Yerel kurulum: http://localhost:11434
# Docker Compose (Ollama host'ta çalışırken): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Görsel analiz için kullanılan multimodal model (LLaVA)
# Kurulum: ollama pull llava:7b
VISION_MODEL=llava:7b

# Çeviri için kullanılan model (TR→EN ve EN→TR)
# Kurulum: ollama pull translategemma:latest
TRANSLATOR_MODEL=translategemma:latest

# Tıbbi analiz için kullanılan model (MedBot / Mistral tabanlı)
MEDICAL_MODEL=Goosedev/medbot:latest

# ─── MCP ENTEGRASYONU (Hastaneler) ───────────────────────────
# Google Maps API anahtarı (hastane arama özelliği için gerekli)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Harici MCP Server kullanılacaksa çalıştırılacak komut (Opsiyonel)
# MCP_SERVER_COMMAND="npx -y @modelcontextprotocol/server-google-maps"

# ─── RAG (RETRIEVAL-AUGMENTED GENERATION) ────────────────────────
# ChromaDB sunucu adresi (Docker üzerinde 8001 portuna haritalandı,
# ancak konteynerlar arası iletişimde 'chromadb' ve '8000' kullanılır)
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Vektörleştirmede (Embedding) kullanılacak Ollama modeli
# Kurulum: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
