# ============================================================
# MediClear — Kapsamlı .gitignore
# Node.js + Python + Ortam Değişkenleri + IDE
# ============================================================

# ─── ORTAM DEĞİŞKENLERİ ─────────────────────────────────────
.env
.env.local
.env.*.local

# ─── NODE.JS ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.npm
.pnp
.pnp.js
dist/
build/

# ─── PYTHON ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Sanal ortamlar
.venv/
venv/
env/
ENV/
.env.python

# uv / pip araçları
uv.lock
.python-version
*.egg-info/
dist/
*.egg
.eggs/

# Type checker / linter
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
pyrightconfig.json

# Jupyter
.ipynb_checkpoints/

# ─── IDE & EDITÖR ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── TESTLER ─────────────────────────────────────────────────
coverage/
.coverage
htmlcov/
.pytest_cache/